@{
    ViewData["Title"] = "Вход в админ панель";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — CS2 Cases</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            background: #0a0e1a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Exo 2', sans-serif;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(255,170,0,0.05) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(255,100,0,0.05) 0%, transparent 40%);
        }

        .login-box {
            background: #111827;
            border: 1px solid #1e2a3a;
            border-radius: 16px;
            padding: 48px 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 24px 80px rgba(0,0,0,0.6);
        }

        .login-logo {
            text-align: center;
            margin-bottom: 32px;
        }

        .login-logo .logo-cs {
            font-family: 'Rajdhani', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: #ffaa00;
        }

        .login-logo .logo-cases {
            font-family: 'Rajdhani', sans-serif;
            font-size: 2rem;
            font-weight: 400;
            color: #ccc;
        }

        .login-logo p {
            color: #6b7280;
            font-size: 0.85rem;
            margin-top: 4px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            color: #9ca3af;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        input[type=text], input[type=password] {
            width: 100%;
            background: #0d1117;
            border: 1px solid #1e2a3a;
            border-radius: 8px;
            padding: 12px 16px;
            color: #e5e7eb;
            font-family: 'Exo 2', sans-serif;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        input[type=text]:focus, input[type=password]:focus {
            border-color: #ffaa00;
        }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, #ffaa00, #ff6600);
            border: none;
            border-radius: 8px;
            padding: 14px;
            color: #000;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 1px;
            cursor: pointer;
            margin-top: 8px;
            transition: opacity 0.2s, transform 0.1s;
        }

        .btn-login:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-login:active { transform: translateY(0); }

        .error-msg {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.3);
            border-radius: 8px;
            color: #f87171;
            padding: 12px 16px;
            margin-bottom: 20px;
            font-size: 0.9rem;
            text-align: center;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 24px;
            color: #4b5563;
            font-size: 0.85rem;
            text-decoration: none;
            transition: color 0.2s;
        }

        .back-link:hover { color: #9ca3af; }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="login-logo">
            <div><span class="logo-cs">CS2</span><span class="logo-cases">CASES</span></div>
            <p>Admin Panel</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="form-group">
                <label>Логин</label>
                <input type="text" name="username" placeholder="admin" autocomplete="off" />
            </div>
            <div class="form-group">
                <label>Пароль</label>
                <input type="password" name="password" placeholder="••••••" />
            </div>
            <button type="submit" class="btn-login">Войти</button>
        </form>

        <a href="/" class="back-link">← Вернуться на сайт</a>
    </div>
</body>
</html>
